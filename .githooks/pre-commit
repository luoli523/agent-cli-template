#!/usr/bin/env bash
# pre-commit: run di-cli convention validator before every commit.
# Opt-in — activate with: git config core.hooksPath .githooks
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if [[ ! -x "$REPO_ROOT/.venv/bin/python" ]]; then
    echo "WARN: .venv not found — skipping convention check (run 'uv sync' to enable)" >&2
    exit 0
fi

bash "$REPO_ROOT/scripts/validate.sh"
